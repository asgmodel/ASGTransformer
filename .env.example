# Local exported repository. Used when models/ASGTransformer/config.json exists.
ASG_MODEL_DIR=models/ASGTransformer

# Hugging Face fallback when no local export is available.
ASG_MODEL_ID=asgmodel/ASGTransformer

ASG_DATA_DIR=data/processed
ASG_TRUST_REMOTE_CODE=true
ASG_TORCH_DTYPE=auto
ASG_DEVICE_MAP=auto
ASG_MAX_NEW_TOKENS=384
ASG_DEFAULT_LANGUAGE=en
ASG_LOG_LEVEL=INFO
